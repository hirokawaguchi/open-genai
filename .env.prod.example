# Open GENAI 本番用の設定（コピーして .env.prod として使用）
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build
#
# 方針: ユーザ公開は proxy のみ。フロントの API 参照は相対 /api。

# === 必須: 公開URL（proxy 経由のベースURL。末尾スラッシュ無し）===
# 本番 TLS:  https://genai.example.lg.jp
# 閉域検証:  http://localhost  （docker-compose.verify.yml と併用）
PUBLIC_URL=https://genai.example.lg.jp

# proxy がホストに公開するポート
# 本番 TLS: PROXY_HTTP_PORT=80, PROXY_HTTPS_PORT=443
# 閉域検証: PROXY_HTTP_PORT=80（80 使用中なら 8080 等。PUBLIC_URL も合わせる）
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# Vite(dev server) に許可させる公開ホスト名（true で全許可、または PUBLIC_URL のホスト）
# 例: genai.example.lg.jp
VITE_ALLOWED_HOSTS=genai.example.lg.jp

# === 認証・鍵（本番では必ず変更）===
APP_JWT_SECRET=please-change-to-a-long-random-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=please-change-me
# backend↔exApp 間の署名鍵（x-user-* 偽装対策）。必須・十分長い乱数（例: openssl rand -hex 32）
INTERNAL_SIGNING_SECRET=please-change-to-a-long-random-secret
# Keycloak 本番DB（既定 dev-file=組込H2 は非推奨。実運用は postgres 等を強く推奨）
# KC_DB=postgres  # 併せて KC_DB_URL / KC_DB_USERNAME / KC_DB_PASSWORD を設定
KC_DB=dev-file

# === LLM 接続（OpenAI 互換）===
OLLAMA_BASE_URL=http://host.docker.internal:11434
# OPENAI_BASE_URL=
# OPENAI_API_KEY=ollama
DEFAULT_MODEL=qwen2.5:7b

# === RAG / 監査 / 各 AI アプリ ===
EMBED_MODEL=mxbai-embed-large
RAG_MODEL=gpt-oss:20b
RAG_API_KEY=change-me-local-rag-key
AUDIT_ENABLED=true
AUDIT_STORE_CONTENT=true
AUDIT_MAX_CONTENT_CHARS=8000
AUDIT_RETENTION_DAYS=1825
# LEGACY_CHAT_OWNER=

# --- 文字起こし / 画像生成 ---
WHISPER_MODEL=medium
WHISPER_COMPUTE=int8
SD_API_URL=http://host.docker.internal:7860

# === 成果物ファイル配信（自前 S3 互換: SeaweedFS）===
S3_ENDPOINT_URL=http://seaweedfs:8333
# 必須: 利用者がインターネットから取得する公開URL（TLS 付きの配信ドメイン）
#   例: https://files.example.lg.jp
S3_PUBLIC_ENDPOINT=https://files.example.lg.jp
S3_BUCKET=open-genai
# seaweedfs/s3.config.json と一致させる（本番用に必ず変更）
S3_ACCESS_KEY=please-change-access-key
S3_SECRET_KEY=please-change-secret-key
# 署名付きURLの有効期限（秒）。データ持ち出しの遅延を見込み本番は長め(例:259200=72h)も検討
S3_PRESIGN_EXPIRY=86400
# 成果物の配信方式（LGWAN 等では carrier 推奨）:
#   open    = 署名付きURLを結果画面に直接リンク（LGWAN 端末では本体を取得できない）
#   carrier = URLを画面に出さず「リンクファイル(.txt/.html)」で持ち出させ、別端末で開く
ARTIFACT_DELIVERY_MODE=carrier
# carrier 時のリンクファイル形式（txt / html / both）。txt が最もフィルタを通りやすい
ARTIFACT_CARRIER_FORMAT=txt
# 成果物取得(SSRF 対策): 生成元の既知ホストのみ許可することを推奨（カンマ区切り）
#   例: ARTIFACT_FETCH_ALLOWED_HOSTS=files.dify.ai,upload.dify.ai
ARTIFACT_FETCH_ALLOWED_HOSTS=
ARTIFACT_MAX_BYTES=52428800
# RAG の URL 取り込み許可ホスト（カンマ区切り）。本市 HP 等の既知ドメインに限定を推奨
#   例: URL_FETCH_ALLOWED_HOSTS=www.city.example.lg.jp
URL_FETCH_ALLOWED_HOSTS=

# ============================================================================
# 閉域検証（HTTP のみ・自己署名証明書不要）
# ============================================================================
# PUBLIC_URL=http://localhost
# PROXY_HTTP_PORT=80
# VITE_ALLOWED_HOSTS=true
# S3_PUBLIC_ENDPOINT=http://localhost:8333  # または別途配信経路
# 起動:
#   docker compose -f docker-compose.prod.yml -f docker-compose.verify.yml \
#     --env-file .env.prod up --build
# アクセス: http://localhost/ （ポート変更時は PUBLIC_URL も合わせる）

# ============================================================================
# 併せて必要な「設定ファイル」側の変更（このファイルでは反映されない項目）
# ============================================================================
# 1) フロントの API 参照は docker-compose で VITE_APP_*=/api を注入済み。
#    ホストで genai-web を直接起動する場合のみ packages/web/.env に設定:
#      VITE_APP_API_ENDPOINT=/api
#      VITE_APP_TEAM_ACCESS_CONTROL_API_ENDPOINT=/api
#
# 2) Keycloak の SAML クライアント(SP)登録を公開URLに合わせる:
#    keycloak/import/realm-open-genai.json の以下を PUBLIC_URL に置換
#    （初回 import 前に編集、または admin コンソールで既存を更新）
#      clientId:                             {PUBLIC_URL}/api/auth/saml/metadata
#      redirectUris:                         {PUBLIC_URL}/api/auth/saml/acs, {PUBLIC_URL}/*
#      saml_assertion_consumer_url_post:     {PUBLIC_URL}/api/auth/saml/acs
#      saml_single_logout_service_url_redirect: {PUBLIC_URL}/api/auth/saml/sls
#
# 3) 本番 TLS 時のみ: 証明書を proxy/certs/{fullchain.pem,privkey.pem} に配置
